{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "types": ["jest", "node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@lifemap/segmentation": ["./packages/segmentation/src/index.ts"],
      "@lifemap/segmentation/*": ["./packages/segmentation/src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "nativewind-env.d.ts"],
  "exclude": ["**/node_modules", "**/Pods", "point-explorer", "scripts"]
}
