{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach to Hermes application",
      "cwd": "${workspaceFolder}",
      "type": "reactnativedirect",
      "request": "attach"
    },
    {
      "name": "Debug iOS Hermes (Device)",
      "cwd": "${workspaceFolder}",
