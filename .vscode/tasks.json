{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Detox iOS: run current e2e file",
      "type": "shell",
      "command": "pnpm e2e:run:ios -- ${relativeFile}",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
