diff --git a/ios/Hybrid Objects/HybridCameraSession.swift b/ios/Hybrid Objects/HybridCameraSession.swift
index b7b0c3cf3cecd28e9abea5404ba02f7301362716..cf587ef3f7da95d8a9d3e3704e7f41b47a12db57 100644
--- a/ios/Hybrid Objects/HybridCameraSession.swift	
+++ b/ios/Hybrid Objects/HybridCameraSession.swift	
@@ -29,6 +29,36 @@ final class HybridCameraSession: HybridCameraSessionSpec {
     super.init()
   }
 
+  deinit {
+    // Gracefully tear down the AVCaptureSession before ARC deallocates it.
+    // Without this, the session can be deallocated (e.g. on the main thread
+    // during a CATransaction commit, via AVCaptureVideoPreviewLayer dealloc)
+    // while its inputs/outputs are still attached â€” AVFoundation then asserts
+    // in `-[AVCaptureOutput detachFromFigCaptureSession:]`, especially on iOS 26.
+    // Stopping the session and detaching all I/O on the shared serial session
+    // queue serializes teardown against any in-flight configure()/start(),
+    // and leaves the session empty so its eventual dealloc is a no-op.
+    // See https://github.com/mrousavy/react-native-vision-camera/issues/4026
+    let session = self.session
+    Self.queue.async {
+      if session.isRunning {
+        session.stopRunning()
+      }
+      session.beginConfiguration()
+      for connection in session.connections {
+        session.removeConnection(connection)
+      }
+      for output in session.outputs {
+        session.removeOutput(output)
+      }
+      for input in session.inputs {
+        session.removeInput(input)
+      }
+      session.commitConfiguration()
+      logger.info("CameraSession torn down gracefully.")
+    }
+  }
+
   var isRunning: Bool {
     return session.isRunning
   }
