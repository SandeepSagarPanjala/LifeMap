# Copy to ios/fastlane/.env (gitignored) or export in your shell.

# Your personal team ID from developer.apple.com → Membership (NOT Gynius AB).
FASTLANE_TEAM_ID=

# App Store Connect → Users and Access → Integrations → App Store Connect API

# Recommended for Fastlane + CI (no app-specific password).
APP_STORE_CONNECT_API_KEY_ID=
APP_STORE_CONNECT_ISSUER_ID=
# Path to AuthKey_XXXXXXXXXX.p8 downloaded from Apple
APP_STORE_CONNECT_API_KEY_PATH=

# Or base64-encode the .p8 file for GitHub Actions secrets:
# APP_STORE_CONNECT_API_KEY_BASE64=

# Optional — interactive upload fallback if no API key.
# FASTLANE_APPLE_ID=you@example.com

# Optional note shown to TestFlight testers.
# TESTFLIGHT_CHANGELOG=Timeline fixes, full GPS capture

# Set to 1 to reuse the current build number (local rebuilds).
# SKIP_BUILD_BUMP=1
