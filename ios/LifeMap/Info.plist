<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
	<string>LifeMap</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>28</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>LifeMap uses your location to build your private life timeline on this device. Routes are stored locally and encrypted—we never upload your location history.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>LifeMap records your daily path in the background so your timeline stays complete, even when the app is closed. All data stays on your phone, encrypted. You can pause tracking anytime in Settings.</string>
	<key>NSMotionUsageDescription</key>
	<string>LifeMap uses motion activity to record your route efficiently and reduce battery use while building your private timeline.</string>
	<key>NSCameraUsageDescription</key>
	<string>LifeMap uses the camera so you can capture photo moments on your map. Photos are stored on this device only.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>LifeMap saves a full-quality copy of camera moments to your Photos library. LifeMap keeps a separate compressed copy for the app.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>LifeMap lets you attach photos from your library to notes. Attached photos are stored on this device only.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>LifeMap uses the microphone so you can record voice memos on your map. Recordings are stored on this device only.</string>
	<key>NSUbiquitousContainers</key>
	<dict>
		<key>iCloud.com.sunrio.lifemap</key>
		<dict>
			<key>NSUbiquitousContainerIsDocumentScopePublic</key>
			<false/>
			<key>NSUbiquitousContainerName</key>
			<string>LifeMap</string>
			<key>NSUbiquitousContainerSupportedFolderLevels</key>
			<string>Any</string>
		</dict>
	</dict>
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
		<string>fetch</string>
		<string>processing</string>
	</array>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.transistorsoft.fetch</string>
		<string>com.sunrio.lifemap.location-wake</string>
	</array>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.sunrio.lifemap</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>lifemap</string>
			</array>
		</dict>
	</array>
	<key>RCTNewArchEnabled</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<false/>
	<key>TSLocationManagerLicense</key>
	<string>$(TRANSISTOR_IOS_LICENSE)</string>
</dict>
</plist>
