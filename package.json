{
  "name": "LifeMap",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "android": "bash scripts/run-android.sh",
    "android:build": "bash -c 'source scripts/android-env.sh && cd android && ./gradlew assembleDebug'",
    "android:emulator": "bash scripts/start-android-emulator.sh",
    "android:create-emulator": "bash scripts/create-android-emulator.sh",
    "ios": "bash scripts/run-ios-device.sh",
    "ios:sim17PM": "react-native run-ios --simulator \"iPhone 17 Pro Max\"",
    "ios:sim:17P": "react-native run-ios --simulator \"iPhone 17 Pro\"",
    "ios:release": "bash -c 'source scripts/ruby-env.sh && cd ios && bundle exec fastlane build'",
    "ios:beta": "bash -c 'source scripts/ruby-env.sh && cd ios && bundle exec fastlane beta'",
    "pod-install": "bash -c 'source scripts/ruby-env.sh && cd ios && bundle exec pod install'",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "start": "react-native start",
    "test": "jest",
    "e2e:setup:ios": "detox clean-framework-cache && detox build-framework-cache",
    "e2e:check:ios": "bash scripts/check-e2e-ios-prereqs.sh",
    "e2e:build:ios": "detox build --configuration ios.sim.debug",
    "e2e:build:android": "detox build --configuration android.emu.debug",
    "e2e:test:ios": "detox test --configuration ios.sim.debug",
    "e2e:test:ios:reuse": "detox test --configuration ios.sim.debug --reuse",
    "e2e:run:ios": "bash scripts/e2e-run-ios.sh",
    "e2e:run:ios:fresh": "E2E_FRESH=1 bash scripts/e2e-run-ios.sh",
    "e2e:test:android": "detox test --configuration android.emu.debug",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@date-fns/tz": "^1.5.0",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@op-engineering/op-sqlite": "^16.2.0",
    "@react-native-async-storage/async-storage": "^3.1.1",
    "@react-native-camera-roll/camera-roll": "^7.10.2",
    "@react-native-documents/picker": "^12.0.1",
    "@react-native/new-app-screen": "0.84.1",
    "@react-navigation/bottom-tabs": "^7.16.2",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/native-stack": "^7.16.0",
    "@rn-primitives/portal": "^1.4.0",
    "@rn-primitives/slot": "^1.4.0",
    "@shopify/flash-list": "^2.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "lottie-react-native": "^7.3.8",
    "lucide-react-native": "^1.17.0",
    "nativewind": "^4.2.4",
    "react": "19.2.3",
    "react-native": "0.84.1",
    "react-native-background-geolocation": "^5.1.1",
    "react-native-blob-util": "^0.24.9",
    "react-native-color-matrix-image-filters": "^8.0.2",
    "react-native-compressor": "^1.19.0",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "^3.0.0",
    "react-native-get-random-values": "^2.0.0",
    "react-native-image-picker": "^8.2.1",
    "react-native-keychain": "^10.0.0",
    "react-native-maps": "^1.27.2",
    "react-native-nitro-image": "0.15.1",
    "react-native-nitro-modules": "^0.35.9",
    "react-native-nitro-sound": "^0.2.15",
    "react-native-reanimated": "^4.4.0",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.25.2",
    "react-native-svg": "^15.15.5",
    "react-native-system-emoji-picker": "^2.0.1",
    "react-native-video": "^6.19.2",
    "react-native-view-shot": "^5.1.0",
    "react-native-vision-camera": "^5.0.11",
    "react-native-worklets": "^0.9.1",
    "react-native-zip-archive": "^8.0.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/eslint-config": "0.84.1",
    "@react-native/metro-config": "0.84.1",
    "@react-native/typescript-config": "0.84.1",
    "@types/jest": "^29.5.13",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "autoprefixer": "^10.5.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "detox": "^20.51.4",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "postcss": "^8.5.15",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "detox"
    ]
  }
}
